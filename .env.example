# development / production
NODE_ENV: development

SITE_URL: https://abu.ua

DOMAIN: localhost

SERVER_URL: http://localhost:8888

API_SERVER_URL: http://localhost:8888/api

NUXT_PUBLIC_KRATOM_CHECKOUT_AGE_VERIFICATION_ENABLED: true
NUXT_PUBLIC_KRATOM_CATALOG_PARENT_CATEGORY_SLUG: kratomshop
# Используйте либо slug, либо id родительской категории каталога.
# NUXT_PUBLIC_KRATOM_CATALOG_PARENT_CATEGORY_ID: 127

NUXT_PUBLIC_ADULTO_PUBLIC_KEY:
NUXT_PUBLIC_ADULTO_WIDGET_SCRIPT_URL: https://api.js.m2a.cz/api.js

IMAGE_PROVIDER: ipx

IMAGE_DIR: public

GTM:

GA:

# UPSTASH REDIS (для кеширования на Vercel)
UPSTASH_REDIS_REST_URL: https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN: your-redis-token

# SUPABASE
SUPABASE_URL:

SUPABASE_KEY:

# NOVAPOSHTA
NOVAPOSHTA_KEY:
